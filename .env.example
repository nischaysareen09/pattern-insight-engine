# Copy to .env and fill in ONE of the sections below to enable real LLM
# narratives. Without any key set, the system still runs end-to-end using
# a documented rule-based fallback narrative (clearly labeled "[fallback]"
# in responses).

# ---- Option 1 (recommended, free): Groq ----
# 1. Go to https://console.groq.com
# 2. Sign up (no credit card required for the free tier)
# 3. Go to "API Keys" and create a new key
# 4. Paste it below
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Option 2 (paid): Anthropic ----
# Only needed if you'd rather use Claude and have a paid API key.
# If GROQ_API_KEY is set above, Groq is used and this is ignored.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
